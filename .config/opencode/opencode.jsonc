{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  /*
    OpenAI Plan
    "model": "openai/gpt-5.5-fast",
    CoPilot Plan
    "model": "github-copilot/gpt-5.3-codex",
    Vertex
    "model": "google-vertex-anthropic/claude-opus-4-6@default",
  */
  "model": "openai/gpt-5.5-fast",
  "agent": {
    "plan": {
      "mode": "primary",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "build": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    },
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini"
    }
  },
  "permission": {
    "external_directory": {
      "~/.bun/**": "allow",
      "~/.config/opencode/opencode.jsonc": "allow",
      "**/*.env": "deny",
      "**/.env*": "deny"
    }
  },
  "plugin": [],
  "mcp": {
    "playwriter": {
      "enabled": true,
      "type": "local",
      "command": ["bunx", "-y", "playwriter@latest"] // https://github.com/remorses/playwriter
    }
  },
  "provider": {
    // Disabled opencode + openrouter models for now - plans are too good of a deal.
    // Provider + Model ID search: https://models.dev
    "opencode": {
      "whitelist": [
        // "kimi-k2.5"
        // "gpt-5.4-nano"
      ]
    },
    "opencode-go": {
      "whitelist": ["glm-5.1", "kimi-k2.5"]
    },
    "openrouter": {
      "whitelist": [
        // "anthropic/claude-opus-4.6"
        "openai/gpt-5.4-nano"
      ]
    },
    "openai": {
      "whitelist": ["gpt-5.3-codex", "gpt-5.4", "gpt-5.4-mini", "gpt-5.5", "gpt-5.5-fast"]
    },
    "github-copilot": {
      "whitelist": [
        "gemini-3-flash-preview",
        "gemini-3.1-pro-preview",
        // "gpt-5.3-codex"
        "claude-sonnet-4.6",
        "claude-opus-4.6"
      ]
    },
    "cloudflare-workers-ai": {
      "whitelist": ["@cf/moonshotai/kimi-k2.5"]
    },
    "github-copilot-enterprise": {
      "whitelist": []
    },
    "github-models": {
      "whitelist": []
    },
    // ----- Work ------
    "google-vertex": {
      "whitelist": [
        // "gemini-3.1-pro-preview"
      ]
    },
    "google-vertex-anthropic": {
      "whitelist": ["claude-sonnet-4-6@default", "claude-opus-4-6@default"]
    }
    // -----------------
  }
}
